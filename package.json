{
  "name": "@skyfall_ai/aegis",
  "version": "0.1.0",
  "description": "Skyfall Aegis — Accessibility-forward, compliance-aware healthcare design system",
  "main": "dist/index.js",
  "module": "dist/index.mjs",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "import": {
        "types": "./dist/index.d.mts",
        "default": "./dist/index.mjs"
      },
      "require": {
        "types": "./dist/index.d.ts",
        "default": "./dist/index.js"
      }
    },
    "./styles": "./dist/index.css",
    "./tokens": "./src/tokens/aegis-tokens.css"
  },
  "files": [
    "dist",
    "src/tokens/*.css"
  ],
  "sideEffects": [
    "**/*.css"
  ],
  "publishConfig": {
    "access": "restricted"
  },
  "scripts": {
    "dev": "storybook dev -p 6006",
    "build": "tsup",
    "build:storybook": "storybook build",
    "typecheck": "tsc --noEmit",
    "clean": "rm -rf dist storybook-static",
    "prepublishOnly": "npm run clean && npm run build",
    "chromatic": "chromatic --project-token=chpt_7828f6d1ed3cc85 --build-script-name=build:storybook"
  },
  "peerDependencies": {
    "react": ">=18.0.0",
    "react-dom": ">=18.0.0"
  },
  "devDependencies": {
    "@storybook/addon-a11y": "^8.6.0",
    "@storybook/addon-essentials": "^8.6.0",
    "@storybook/react": "^8.6.0",
    "@storybook/react-vite": "^8.6.0",
    "@types/react": "^18.3.0",
    "@types/react-dom": "^18.3.0",
    "chromatic": "^15.2.0",
    "react": "^18.3.0",
    "react-dom": "^18.3.0",
    "storybook": "^8.6.0",
    "tsup": "^8.3.0",
    "typescript": "^5.6.0",
    "vite": "^8.0.0"
  },
  "keywords": [
    "healthcare",
    "design-system",
    "react",
    "accessibility",
    "wcag",
    "components",
    "ui"
  ],
  "license": "MIT",
  "homepage": "https://github.com/gerardovinces/skyfall-aegis#readme",
  "repository": {
    "type": "git",
    "url": "https://github.com/gerardovinces/skyfall-aegis.git"
  }
}
